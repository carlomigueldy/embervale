{
  "name": "embervale",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cozy angled top-down voxel PvE with waves, bosses, R3F + Rapier, and Blender bpy assets.",
  "scripts": {
    "dev": "vite --port 2035 --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 2035 --host",
    "typecheck": "tsc -b --pretty",
    "lint": "oxlint",
    "assets:generate": "blender --background --python tools/blender/generate_assets.py"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
